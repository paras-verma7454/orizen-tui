{
  "name": "orizen-tui",
  "type": "module",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "generate:docs": "bun run packages/registry/scripts/generate-web-component-docs.ts",
    "demo": "bun run packages/demo/src/index.tsx",
    "dev:web": "bun run --filter './packages/web' dev",
    "build": "bun run generate:docs && bun run --filter './packages/*' build",
    "dev": "bun run --filter './packages/*' dev",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "typecheck": "bun run generate:docs && bun run --filter './packages/*' typecheck",
    "lint": "bunx eslint .",
    "lint:fix": "bunx eslint . --fix"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.2.0",
    "@orizen-tui/registry": "workspace:*",
    "@types/bun": "^1.3.11",
    "@types/node": "^22.10.7",
    "@types/react": "^18.3.18",
    "eslint": "^9.39.2",
    "orizen-tui-core": "workspace:*",
    "publint": "^0.3.18",
    "tsdown": "^0.17.3",
    "typescript": "^5.9.3"
  }
}
