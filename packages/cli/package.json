{
  "name": "orizen-tui",
  "type": "module",
  "version": "0.1.4",
  "description": "Add beautiful terminal UI components to your project",
  "bin": {
    "orizen-tui": "dist/index.mjs"
  },
  "files": [
    "dist",
    "registry-source",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown && node ./scripts/sync-registry-source.mjs",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^13.0.0",
    "execa": "^9.5.1",
    "fs-extra": "^11.2.0",
    "jiti": "^2.4.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.10.7",
    "tsdown": "^0.17.3",
    "typescript": "^5.9.3"
  }
}
