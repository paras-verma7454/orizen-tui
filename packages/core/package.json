{
  "name": "orizen-tui-core",
  "type": "module",
  "version": "0.1.14",
  "description": "Theme system and primitives for building terminal user interfaces",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown --publint false && bun -e \"if(require('node:fs').existsSync('dist/index.d.mts')){require('node:fs').renameSync('dist/index.d.mts','dist/index.d.ts');console.log('Renamed d.mts to d.ts')}\" && bunx publint .",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22.10.7",
    "@types/react": "^18.3.18",
    "ink": "^5.0.1",
    "ink-testing-library": "^3.0.0",
    "react": "^18.3.1",
    "tsdown": "^0.17.3",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "yoga-layout": "yoga-layout-prebuilt"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.mjs"
      },
      "./package.json": "./package.json"
    }
  }
}
